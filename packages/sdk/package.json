{
  "name": "@tael/sdk",
  "version": "0.2.2",
  "type": "module",
  "description": "The Tael SDK: call any capability with one API key, or wrap your own service with x402 payments in one line.",
  "license": "MIT",
  "keywords": [
    "tael",
    "x402",
    "payments",
    "ai-agents",
    "stellar",
    "usdc"
  ],
  "homepage": "https://taelprotocol.xyz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tael-protocol/tael.git",
    "directory": "packages/sdk"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@tael/config": "workspace:*",
    "@tael/payments": "workspace:*",
    "@tael/types": "workspace:*",
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
