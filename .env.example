# =============================================================================
# Tael — environment contract
# =============================================================================
# Copy to `.env` and fill in. NEVER commit a real `.env`.
# Each app validates the subset it needs at boot via a zod schema (see
# apps/*/src/env.ts). Adding a new variable? Document it here AND add it to the
# owning app's env schema — the schema is the source of truth, this file is the
# contract.
# -----------------------------------------------------------------------------

# --- Runtime ---
NODE_ENV=development

# --- API (apps/api) ---
API_PORT=3001
# Public origin the API is served from (used for CORS + x402 challenge URLs).
API_PUBLIC_URL=http://localhost:3001

# --- Database (PostgreSQL / Supabase) — @tael/database ---
# Pooled connection (Supabase transaction pooler, :6543) used by the app at runtime.
DATABASE_URL=postgresql://postgres:postgres@localhost:6543/postgres
# Direct/session connection (:5432) used by migrations.
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/postgres
# 32-byte key (hex or base64) that encrypts capability upstream secrets at rest.
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# --- Auth (Sign-In-With-Stellar) — apps/dashboard ---
# Secret used to sign session + challenge JWTs (@tael/auth). Use a strong random
# value (>= 32 chars) in production. In Vercel, set this on the dashboard project.
AUTH_SECRET=

# --- Blockchain (Stellar) — consumed by packages/stellar via apps/api ---
# "testnet" | "mainnet"
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
# Canonical USDC asset issuer on the selected network.
USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

# --- Payments (x402) ---
# Facilitator that verifies/settles x402 payment proofs.
X402_FACILITATOR_URL=
# Marketplace fee (apps/api gateway). When TAEL_FEE_ADDRESS is set, the gateway
# routes TAEL_FEE_BPS of each call's price to it in the same transaction
# (non-custodial). Leave the address blank to disable the fee. 100 bps = 1%.
TAEL_FEE_ADDRESS=
TAEL_FEE_BPS=100

# --- Web (apps/web) ---
# NEXT_PUBLIC_* values are exposed to the browser — never put secrets here.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# Waitlist signup emails (apps/web /api/waitlist), sent via Resend.
# RESEND_API_KEY: from resend.com → API Keys. Server-only secret.
RESEND_API_KEY=
# Inbox that receives "someone is interested in Tael" notifications.
WAITLIST_NOTIFY_EMAIL=
# Verified sender. Requires the domain to be verified in Resend → Domains.
# Until taelprotocol.xyz is verified you can test with "Tael <onboarding@resend.dev>"
# (that can ONLY email your own Resend account address).
WAITLIST_FROM_EMAIL="Tael <hello@taelprotocol.xyz>"

# --- Dashboard (apps/dashboard) ---
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3002
# Network the wallet connects to (client-exposed). "testnet" | "mainnet".
NEXT_PUBLIC_STELLAR_NETWORK=testnet
