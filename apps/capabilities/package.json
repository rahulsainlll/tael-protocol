{
  "name": "capabilities",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Tael's first-party capabilities: a small service of useful, Stellar-native endpoints that are published to the Tael marketplace.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "gen": "node scripts/gen-registry.mjs",
    "dev": "node scripts/gen-registry.mjs && tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "node scripts/gen-registry.mjs && tsup",
    "typecheck": "node scripts/gen-registry.mjs && tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "publish:capabilities": "node scripts/gen-registry.mjs && tsx src/publish.ts"
  },
  "dependencies": {
    "@hono/node-server": "catalog:",
    "@tael/sdk": "workspace:*",
    "hono": "catalog:"
  },
  "devDependencies": {
    "@tael/config": "workspace:*",
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
